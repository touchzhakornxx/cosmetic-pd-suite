SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://user:password@db-host:5432/postgres
# Or use SUPABASE_DB_URL if you prefer
SUPABASE_DB_URL=postgresql://user:password@db-host:5432/postgres
# Personal Access Token for the Supabase Management API (schema deploy fallback).
# Generate one at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token
